rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== FUNCIONES AUXILIARES =====
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isBarber() {
      return isAuthenticated() && getUserRole() == 'barber';
    }

    // ===== USUARIOS =====
    match /users/{userId} {
      // Privacidad: solo el propio usuario o un admin leen el perfil.
      // (Los barberos visibles para reservar viven en la coleccion 'barbers'.)
      allow read: if isOwner(userId) || isAdmin();

      // Un usuario solo puede crear SU PROPIO documento (uid == auth.uid).
      allow create: if isOwner(userId);

      // El propio usuario edita su perfil PERO NO puede cambiar su rol
      // (evita escalada de privilegios: que un cliente se vuelva admin).
      // Solo el admin puede cambiar roles (para promover/quitar barberos).
      allow update: if isAdmin() ||
        (isOwner(userId) &&
         request.resource.data.role == resource.data.role);

      // Solo admins eliminan usuarios.
      allow delete: if isAdmin();
    }

    // ===== SERVICIOS =====
    match /services/{serviceId} {
      // Todos los autenticados pueden ver servicios
      allow read: if isAuthenticated();
      // Solo admins pueden crear/editar/eliminar servicios
      allow write: if isAdmin();
    }

    // ===== BARBEROS =====
    match /barbers/{barberId} {
      allow read: if isAuthenticated();
      // El propio barbero puede actualizar su perfil
      allow update: if isOwner(barberId) || isAdmin();
      allow create, delete: if isAdmin();
    }

    // ===== CITAS =====
    match /appointments/{appointmentId} {
      // Lectura para usuarios autenticados: el cliente necesita consultar
      // las citas del barbero para calcular los horarios disponibles al
      // reservar. (MVP: en V2 conviene mover la disponibilidad a un
      // documento agregado para no exponer datos de otras citas.)
      allow read: if isAuthenticated();
      // Clientes pueden crear citas
      allow create: if isAuthenticated() &&
        request.resource.data.clientId == request.auth.uid;
      // Cliente puede cancelar, barbero puede confirmar/rechazar/completar
      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.barberId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ===== HORARIOS =====
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isBarber();
    }
  }
}
